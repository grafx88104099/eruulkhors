rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && (request.auth.token.role == 'super_admin' || request.auth.token.role == 'dispatcher');
    }

    // Order evidence (photos + signature) — only the assigned technician or admin
    match /orders/{orderId}/{file=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.resource.size < 8 * 1024 * 1024;
    }
  }
}
